# Cloudflare Workers Environment Variables
# These are set via `wrangler secret put` commands

# Database URL (for drizzle-kit, not used in runtime)
DATABASE_URL=https://your-account-id.cloudflare.com/d1/databases/your-database-id

# Authentication
AUTH_SECRET=your-32-character-secret-key-here
AUTH_REDIRECT_URL=https://your-domain.com/auth/callback

# Email (optional)
EMAIL_FROM=noreply@your-domain.com

# Environment
NODE_ENV=development

# Legacy variables (for compatibility)
BACKEND_URL=http://localhost:8787
FRONTEND_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:8787

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

BETTER_AUTH_SECRET=
ENVIRONMENT=development

CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_DATABASE_ID=your-dev-database-id
CLOUDFLARE_API_TOKEN=your-api-token
