{
  "name": "worker-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Sajib Chakma <sajibchakmahust@gmail.com>",
  "description": "A Cloudflare Workers backend for managing API endpoints, built with Hono and Drizzle ORM.",
  "keywords": ["cloudflare-workers", "backend", "hono", "drizzle-orm", "typescript"],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=9.0.0"
  },
  "main": "src/main.ts",
  "scripts": {
    "dev":              "wrangler dev",
    "dev:local":        "wrangler dev --local",

    "deploy:staging":   "wrangler deploy --env staging",
    "deploy:prod":      "wrangler deploy --env production",

    "build":            "wrangler deploy --dry-run --outdir dist",
    "types:gen":        "wrangler types",

    "db:generate":      "drizzle-kit generate",
    "db:studio":        "drizzle-kit studio",
    "db:migrate:local":   "wrangler d1 migrations apply DB --local",
    "db:migrate:staging": "wrangler d1 migrations apply DB --remote --env staging",
    "db:migrate:prod":    "wrangler d1 migrations apply DB --remote --env production",

    "lint":       "biome lint .",
    "lint:fix":   "biome lint . --write",
    "format":     "biome format . --write",
    "check":      "biome check .",
    "check:fix":  "biome check . --write",
    "typecheck":  "tsc --noEmit",

    "test":           "vitest run",
    "test:watch":     "vitest watch",
    "test:coverage":  "vitest run --coverage",

    "ci": "pnpm check && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@cloudflare/workers-types": "^4.20260416.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
