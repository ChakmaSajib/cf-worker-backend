{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main.ts"],
  "project": ["src/**/*.ts"],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/config/**",
    "src/db/**",
    "src/errors/**",
    "src/jobs/**",
    "src/lib/**",
    "src/middleware/**",
    "src/types/**",
    "src/utils/**"
  ],
  "ignoreDependencies": ["@hono/zod-openapi", "better-auth", "drizzle-orm", "pino", "zod"],
  "ignoreBinaries": ["check"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "off",
    "dependencies": "off",
    "unlisted": "off",
    "exports": "off",
    "types": "off",
    "duplicates": "warn"
  }
}
